{
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm run start)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(zig build)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read(~/.zshrc)"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_PROJECT_DIR}/AGENTS.md\"; [ -f \"$f\" ] || exit 0; grep -qs \"@AGENTS.md\" \"${CLAUDE_PROJECT_DIR}/CLAUDE.md\" && exit 0; echo \"=== Project AGENTS.md ===\"; cat \"$f\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "cloudflare@cloudflare": false,
    "security-guidance@claude-plugins-official": false,
    "figma@claude-plugins-official": true
  },
  "effortLevel": "high"
}
